{
  "manifest_version": 3,
  "name": "譯",
  "version": "1.3.0",
  "description": "開源雙語對照翻譯。快速閱讀，無伺服器，無追蹤。",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "contextMenus"
  ],

  "side_panel": {
    "default_path": "options/index.html"
  },

  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],

  "optional_host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ]
}