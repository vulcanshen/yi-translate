{
  "manifest_version": 3,
  "name": "譯",
  "version": "0.1.0",
  "description": "開源雙語對照翻譯。快速閱讀，無伺服器，無追蹤。",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],

  "background": {
    "service_worker": "background/index.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup/index.html"
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ]
}