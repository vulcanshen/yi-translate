{
  "manifest_version": 3,
  "name": "譯 Yi",
  "version": "1.2.0",
  "description": "開源雙語對照翻譯。快速閱讀，無伺服器，無追蹤。",

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab",
    "contextMenus"
  ],

  "host_permissions": [
    "https://translate.googleapis.com/*"
  ],

  "optional_permissions": [
    "*://*/*"
  ],

  "background": {
    "scripts": ["background/index.js"],
    "type": "module"
  },

  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    }
  },

  "sidebar_action": {
    "default_panel": "options/index.html",
    "default_title": "譯 Yi",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/index.js"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "yi@yi-translate.dev",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}