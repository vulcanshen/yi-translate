{
  "manifest_version": 3,
  "name": "FreeBabel",
  "version": "0.1.0",
  "description": "Open-source bilingual translation. No servers, no tracking.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "contextMenus"
  ],

  "host_permissions": [
    "https://api.deepl.com/*",
    "https://api-free.deepl.com/*",
    "https://translation.googleapis.com/*"
  ],

  "background": {
    "scripts": ["background/index.js"],
    "type": "module"
  },

  "action": {
    "default_popup": "popup/index.html"
  },

  "options_ui": {
    "page": "options/index.html",
    "open_in_tab": true
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "freebabel@freebabel.dev",
      "strict_min_version": "109.0"
    }
  }
}